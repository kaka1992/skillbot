# Hermes Agent Environment Configuration
# Copy this file to ~/.hermes/.env and fill in your API keys

# Enable API server
API_SERVER_ENABLED=true
API_SERVER_KEY=1234
GATEWAY_ALLOW_ALL_USERS=true

# =============================================================================
# LLM PROVIDERS (at least one required)
# =============================================================================

# OpenRouter — unified access to all models
# Get your key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# Anthropic — Claude direct API
# Get your key at: https://console.anthropic.com
# ANTHROPIC_API_KEY=

# OpenAI — GPT models + Whisper transcription
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Google AI Studio / Gemini
# Get your key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# DeepSeek
# Get your key at: https://platform.deepseek.com
# DEEPSEEK_API_KEY=

# Kimi / Moonshot
# Get your key at: https://platform.kimi.ai
# KIMI_API_KEY=

# Z.AI / GLM
# Get your key at: https://z.ai or https://open.bigmodel.cn
# GLM_API_KEY=

# MiniMax (global)
# Get your key at: https://www.minimax.io
# MINIMAX_API_KEY=

# Hugging Face Inference Providers
# Get your token at: https://huggingface.co/settings/tokens
# HF_TOKEN=

# Groq — fast inference + Whisper STT
# Get your key at: https://console.groq.com
# GROQ_API_KEY=

# SiliconFlow (硅基流动)
# Get your key at: https://siliconflow.cn
# SILICONFLOW_API_KEY=

# =============================================================================
# TOOL API KEYS (optional — enables web search, image gen, etc.)
# =============================================================================

# Exa — AI-native web search
# Get at: https://exa.ai
# EXA_API_KEY=

# Firecrawl — web search, extract, and crawl
# Get at: https://firecrawl.dev
# FIRECRAWL_API_KEY=

# FAL.ai — image generation
# Get at: https://fal.ai
# FAL_KEY=

# Browserbase — cloud browser automation
# Get at: https://browserbase.com
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
BROWSERBASE_PROXIES=true
BROWSERBASE_ADVANCED_STEALTH=false

# =============================================================================
# MESSAGING CHANNELS (optional)
# =============================================================================

# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Email (IMAP/SMTP)
# EMAIL_ADDRESS=
# EMAIL_PASSWORD=
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587

# =============================================================================
# TERMINAL CONFIGURATION
# =============================================================================

TERMINAL_TIMEOUT=60
# TERMINAL_ENV=local

# SSH remote execution
# TERMINAL_SSH_HOST=
# TERMINAL_SSH_USER=
# TERMINAL_SSH_PORT=22

# Docker runtime override (e.g. podman)
# HERMES_DOCKER_BINARY=/usr/local/bin/podman

# =============================================================================
# DEBUG / OBSERVABILITY
# =============================================================================

WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false

# Langfuse observability (optional)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=

# GitHub token (for skills hub rate limits)
# GITHUB_TOKEN=
