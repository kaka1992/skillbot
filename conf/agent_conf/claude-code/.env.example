# Claude Code HTTP Server Configuration
# Copy this file to conf/.env or export before starting

# Server bind
# CLAUDE_SERVER_HOST=127.0.0.1
# CLAUDE_SERVER_PORT=9000

# Request timeout (seconds)
# CLAUDE_SERVER_TIMEOUT=300

# Comma-separated tool allowlist (empty = all tools)
# CLAUDE_SERVER_ALLOWED_TOOLS=Read,Write,Bash

# Working directory for claude process
# CLAUDE_SERVER_WORK_DIR=.

